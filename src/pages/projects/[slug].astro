---
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import { renderMarkdoc } from '../../lib/markdoc';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const d = project.data;

const details = [
  ['Client', d.client],
  ['Role', d.role],
  ['Category', d.category],
  ['Year', d.year],
].filter(([, v]) => v);

const sections = [
  ['Overview', renderMarkdoc(d.overview)],
  ['Approach', renderMarkdoc(d.approach)],
  ['Outcome', renderMarkdoc(d.outcome)],
].filter(([, html]) => html);

const gallery = [d.image2, d.image3, d.image4, d.image5, d.image6, d.image7, d.image8, d.image9, d.image10].filter(
  (i) => i != null
);

// related projects: same category first, then next-in-order (wrapping), 3 total
const all = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const idx = all.findIndex((p) => p.id === project.id);
const sameCategory = all.filter((p) => p.id !== project.id && p.data.category === d.category);
const nextInOrder = [...all.slice(idx + 1), ...all.slice(0, idx)];
const related = [...new Set([...sameCategory, ...nextInOrder])].filter((p) => p.id !== project.id).slice(0, 3);
---

<Base title={`${d.title} – Nick Kidd`} description={d.summary}>
  <section class="single-project-section">
    <div class="w-layout-blockcontainer main-container w-container">
      <div class="div-block-42">
        <div class="div-block-49">
          <a href="/work" class="text-block-18 inline-flex items-center gap-2">
            <img
              src="/assets/6711338183204ff65e11a137_arrow-black.svg"
              alt=""
              width="15"
              height="13"
              class="h-[13px] w-auto shrink-0 rotate-180"
            />
            ALL PROJECTS
          </a>
        </div>
        <h2 class="single-proj-header">{d.title}</h2>
        <p class="paragraph-14">{d.summary}</p>
      </div>
      <div class="div-block-43">
        {details.map(([label, value]) => (
          <div class="projectdetails">
            <h1 class="projdescriptionhead">{label}</h1>
            <div class="text-block-17">{value}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="div-block-48">
    {/* hero rule: video1 (raw upload) wins, then heroEmbed (YouTube/Vimeo link), then image1 */}
    {
      d.video1 ? (
        <video
          class="project-img"
          autoplay
          loop
          muted
          playsinline
          data-lazy-video
          aria-label={`${d.title} hero video`}
        >
          <source data-src={d.video1} type="video/mp4" />
        </video>
      ) : d.heroEmbed ? (
        <VideoEmbed url={d.heroEmbed} />
      ) : d.image1 ? (
        <Image src={d.image1} alt={d.title} class="project-img" widths={[800, 1280, 1920]} sizes="100vw" />
      ) : null
    }
  </div>

  <section class="single-content-section">
    {sections.length > 0 && (
      <div class="w-layout-blockcontainer container-12 w-container">
        {sections.map(([label, html]) => (
          <>
            <h1 class="projdescriptionhead">{label}</h1>
            <div class="project-body w-richtext" set:html={html} />
          </>
        ))}
      </div>
    )}

    {d.videoEmbeds.map((url) => (
      <div class="videowrapper">
        <VideoEmbed url={url} />
      </div>
    ))}

    {gallery.length > 0 && (
      <div class="w-layout-blockcontainer container-13 w-container">
        {gallery.map((img, i) => (
          <Image
            src={img!}
            alt={`${d.title} — image ${i + 2}`}
            class={`image-${19 + i}`}
            widths={[800, 1280, 1920]}
            sizes="(max-width: 767px) 100vw, 90vw"
            loading="lazy"
          />
        ))}
      </div>
    )}

  </section>

  {/* related projects: same category first, padded with the next in order */}
  <section class="border-t border-line px-6 py-20" aria-label="More work">
    <div class="mx-auto max-w-6xl">
      <div class="mb-10 flex flex-wrap items-baseline justify-between gap-4" data-reveal>
        <h2 class="font-display text-[clamp(1.6rem,3vw,2.4rem)] leading-none text-ink uppercase">More work</h2>
        <a
          href="/work"
          class="group font-body text-[13px] font-semibold tracking-[0.2em] text-ink uppercase hover:text-purple"
        >
          All projects <span aria-hidden="true" class="ml-1 inline-block transition-transform duration-300 group-hover:translate-x-1.5">→</span>
        </a>
      </div>
      <div class="grid grid-cols-1 gap-9 md:grid-cols-3">
        {related.map((p) => (
          <a href={`/projects/${p.id}`} class="group block" data-reveal>
            {p.data.image1 && (
              <Image
                src={p.data.image1}
                alt={p.data.title}
                widths={[600, 900]}
                sizes="(max-width: 767px) 100vw, 33vw"
                loading="lazy"
                class="aspect-video w-full object-cover"
              />
            )}
            <p class="mt-4 font-body text-[12px] tracking-[0.2em] text-ink/50 uppercase">
              {p.data.category}
              {p.data.year && (
                <>
                  <span aria-hidden="true" class="mx-2 text-ink/30">|</span>
                  {p.data.year}
                </>
              )}
            </p>
            <p class="mt-1.5 font-display text-[clamp(1.2rem,2vw,1.6rem)] leading-tight text-ink uppercase group-hover:text-purple">
              {p.data.title}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
