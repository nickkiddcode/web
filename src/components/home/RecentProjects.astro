---
// "Recent Projects" — card grid + full-bleed feature list, both inside the
// footer.projects wrapper exactly as the source page nests them.
// Data extracted from the crawl (src/data/home.json); becomes the Projects
// collection when the Keystatic schema lands.
import home from '../../data/home.json';
const arrow = '/assets/6711338183204ff65e11a115_arrow.svg';
---

<footer class="projects">
  <div class="div-block-50">
    <h1 class="heading-30">Recent Projects</h1>
    <a href="/work" class="link-block-3 w-inline-block">
      <div class="text-block-19">All Projects</div>
      <img src={arrow} loading="lazy" alt="" />
    </a>
  </div>

  <div class="collection-list-wrapper-2 w-dyn-list">
    <div role="list" class="w-dyn-items">
      {home.grid.map((p) => (
        <div role="listitem" class="collection-item-3 w-dyn-item" data-project-card>
          <div class="div-block-34">
            <a href={p.href} class="link-block w-inline-block" aria-label={p.title}></a>
            <div class="projecttext">
              <div class="div-block-36">
                <div class="text-block-10">{p.category}</div>
                <div class="text-block-12">| </div>
                <div class="text-block-11">{p.year}</div>
              </div>
              <h4 class="heading-28">{p.title}</h4>
              {p.summary && <p class="projectsummary" data-card-reveal>{p.summary}</p>}
              <div class="div-block-40" data-card-reveal>
                <div class="div-block-37">
                  <div class="text-block-13">View Project</div>
                  <img src={arrow} loading="lazy" alt="" />
                </div>
                <div class="linediv" data-card-line></div>
              </div>
            </div>
            <div class="div-block-39" data-card-overlay></div>
            {p.image?.src && (
              <img
                src={p.image.src}
                srcset={p.image.srcset}
                sizes={p.image.sizes ?? '100vw'}
                loading="lazy"
                alt={p.title}
                class="image-15"
              />
            )}
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="collection-list-wrapper-3 w-dyn-list">
    <div role="list" class="collection-list-2 w-dyn-items">
      {home.features.map((p) => (
        <div role="listitem" class="collection-item-4 w-dyn-item">
          <a href={p.href} class="link-block-2 w-inline-block" aria-label={p.title}></a>
          <div class="div-block-44" data-feature-reveal>
            {p.image1?.src && (
              <img src={p.image1.src} srcset={p.image1.srcset} sizes="100vw" loading="lazy" alt="" class="image1" />
            )}
            {p.image2?.src && (
              <img src={p.image2.src} srcset={p.image2.srcset} sizes="100vw" loading="lazy" alt="" class="image2" />
            )}
          </div>
          <div class="div-block-46"></div>
          <div class="div-block-41" data-feature-reveal>
            <div class="div-block-45">
              <div class="div-block-36">
                <div class="projdescriptionhead white">{p.category}</div>
                <div class="projdescriptionhead white">| </div>
                <div class="projdescriptionhead white">{p.year}</div>
              </div>
              <h1 class="heading-29">{p.title}</h1>
              <div class="div-block-40">
                <div class="div-block-37">
                  <div class="text-block-13">View Project</div>
                  <img src={arrow} loading="lazy" alt="" data-feature-arrow />
                </div>
                <div class="linediv" data-feature-line></div>
              </div>
            </div>
            <div class="div-block-47">
              <p class="paragraph-9">{p.summary}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</footer>
