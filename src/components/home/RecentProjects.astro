---
// "Recent Projects" — card grid (hidden on the live site, markup preserved) +
// full-bleed feature list, both inside the footer.projects wrapper as in the
// source. Driven by the Projects collection so Keystatic edits flow through.
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const arrow = '/assets/6711338183204ff65e11a115_arrow.svg';
---

<footer class="projects">
  <div class="div-block-50">
    <h1 class="heading-30">Recent Projects</h1>
    <a href="/work" class="link-block-3 w-inline-block">
      <div class="text-block-19">All Projects</div>
      <img src={arrow} loading="lazy" alt="" />
    </a>
  </div>

  <div class="collection-list-wrapper-2 w-dyn-list">
    <div role="list" class="w-dyn-items">
      {projects.map((p) => (
        <div role="listitem" class="collection-item-3 w-dyn-item" data-project-card>
          <div class="div-block-34">
            <a href={`/projects/${p.id}`} class="link-block w-inline-block" aria-label={p.data.title}></a>
            <div class="projecttext">
              <div class="div-block-36">
                <div class="text-block-10">{p.data.category}</div>
                <div class="text-block-12">| </div>
                <div class="text-block-11">{p.data.year}</div>
              </div>
              <h4 class="heading-28">{p.data.title}</h4>
              {p.data.summary && <p class="projectsummary" data-card-reveal>{p.data.summary}</p>}
              <div class="div-block-40" data-card-reveal>
                <div class="div-block-37">
                  <div class="text-block-13">View Project</div>
                  <img src={arrow} loading="lazy" alt="" />
                </div>
                <div class="linediv" data-card-line></div>
              </div>
            </div>
            <div class="div-block-39" data-card-overlay></div>
            {p.data.image1 && (
              <Image src={p.data.image1} alt={p.data.title} class="image-15" widths={[800, 1280]} sizes="100vw" loading="lazy" />
            )}
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="collection-list-wrapper-3 w-dyn-list">
    <div role="list" class="collection-list-2 w-dyn-items">
      {projects.map((p) => (
        <div role="listitem" class="collection-item-4 w-dyn-item">
          <a href={`/projects/${p.id}`} class="link-block-2 w-inline-block" aria-label={p.data.title}></a>
          <div class="div-block-44" data-feature-reveal>
            {p.data.image1 && (
              <Image src={p.data.image1} alt="" class="image1" widths={[800, 1280, 1920]} sizes="100vw" loading="lazy" />
            )}
            {p.data.image2 && (
              <Image src={p.data.image2} alt="" class="image2" widths={[800, 1280, 1920]} sizes="100vw" loading="lazy" />
            )}
          </div>
          <div class="div-block-46"></div>
          <div class="div-block-41" data-feature-reveal>
            <div class="div-block-45">
              <div class="div-block-36">
                <div class="projdescriptionhead white">{p.data.category}</div>
                <div class="projdescriptionhead white">| </div>
                <div class="projdescriptionhead white">{p.data.year}</div>
              </div>
              <h1 class="heading-29">{p.data.title}</h1>
              <div class="div-block-40">
                <div class="div-block-37">
                  <div class="text-block-13">View Project</div>
                  <img src={arrow} loading="lazy" alt="" data-feature-arrow />
                </div>
                <div class="linediv" data-feature-line></div>
              </div>
            </div>
            <div class="div-block-47">
              <p class="paragraph-9">{p.data.summary}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</footer>
