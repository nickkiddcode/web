---
// Best-practice video embeds (approved: drop Embedly wrappers).
// YouTube: click-to-load facade — poster from YouTube's own image CDN, iframe
// only created on click. Vimeo: native lazy iframe.
//
// Self-contained aspect-ratio box: the pages that use this component wrap it
// in Webflow-ported classes (.video-6/.video-2/.w-video) whose ported CSS
// conflicts with the padding-top aspect-ratio trick (.video-6 sets
// position:absolute with no offsets, and the child-selector that sizes
// iframes doesn't match our <button> facade). Establishing our own
// position/aspect-ratio here sidesteps that cascade fight entirely.
interface Props {
  url: string;
}
const { url } = Astro.props;

const yt = url.match(/youtube\.com\/(?:embed\/|watch\?v=)([\w-]{6,})/);
const vimeo = url.match(/player\.vimeo\.com\/video\/(\d+)/);
const ytId = yt?.[1];
const vimeoSrc = vimeo ? `https://player.vimeo.com/video/${vimeo[1]}?dnt=1` : null;
---

<div class="embed-box">
  {
    ytId ? (
      <button
        class="yt-facade"
        data-yt-id={ytId}
        type="button"
        aria-label="Play video"
        data-maxres-src={`https://i.ytimg.com/vi/${ytId}/maxresdefault.jpg`}
        style={`background-image:url(https://i.ytimg.com/vi/${ytId}/hqdefault.jpg)`}
      >
        <span class="yt-facade-play" aria-hidden="true">
          <svg viewBox="0 0 68 48" width="68" height="48">
            <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="#f00" />
            <path d="M45 24 27 14v20" fill="#fff" />
          </svg>
        </span>
      </button>
    ) : vimeoSrc ? (
      <iframe
        src={vimeoSrc}
        loading="lazy"
        frameborder="0"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        title="Vimeo video"
      />
    ) : null
  }
</div>

<style>
  .embed-box {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: #000;
  }
  .yt-facade,
  .embed-box iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .yt-facade {
    display: block;
    padding: 0;
    cursor: pointer;
    background-color: #000;
    background-size: cover;
    background-position: center;
  }
  .yt-facade-play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    opacity: 0.9;
    transition: opacity 0.2s;
  }
  .yt-facade:hover .yt-facade-play {
    opacity: 1;
  }
</style>

<script>
  // The hero renders at full page width, so the standard hqdefault thumbnail
  // (480x360) visibly pixelates when stretched. Opportunistically upgrade to
  // maxresdefault (1280x720) — not every video has one, and YouTube returns a
  // fake 120x90 placeholder instead of a 404 when it's missing, so we detect
  // that by checking the loaded image's real width rather than trusting a
  // successful load.
  for (const btn of document.querySelectorAll<HTMLButtonElement>('.yt-facade[data-maxres-src]')) {
    const probe = new Image();
    probe.onload = () => {
      if (probe.naturalWidth > 120) {
        btn.style.backgroundImage = `url(${btn.dataset.maxresSrc})`;
      }
    };
    probe.src = btn.dataset.maxresSrc!;
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.yt-facade');
    if (!btn) return;
    const iframe = document.createElement('iframe');
    iframe.src = `https://www.youtube-nocookie.com/embed/${btn.dataset.ytId}?autoplay=1`;
    iframe.allow = 'autoplay; fullscreen; encrypted-media; picture-in-picture';
    iframe.allowFullscreen = true;
    iframe.title = 'YouTube video';
    iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';
    btn.replaceWith(iframe);
  });
</script>
